{
  "name": "app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "prisma generate && next dev --webpack",
    "dev:turbo": "prisma generate && next dev --turbopack",
    "build": "next build",
    "build:vercel": "tsx scripts/vercel-build.ts",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:unit": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:unit:notifications": "vitest run src/app/api/notifications/route.test.ts src/server/actions/notification.test.ts src/server/queries/notification.queries.test.ts src/server/auth.test.ts",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "ENABLE_SOCIAL_DEV_LOGIN=1 playwright test e2e/feed-loading-skeleton.spec.ts e2e/kakao-login-entry.spec.ts e2e/naver-login-entry.spec.ts e2e/social-onboarding-flow.spec.ts --project=chromium",
    "test:e2e:auth": "ENABLE_SOCIAL_DEV_LOGIN=1 PLAYWRIGHT_BASE_URL=http://localhost:3000 playwright test e2e/auth-session-hardening.spec.ts e2e/profile-social-account-linking.spec.ts --project=chromium --workers=1",
    "quality:check": "pnpm lint && pnpm typecheck && pnpm test:unit",
    "quality:gate": "pnpm quality:check && pnpm test:e2e:smoke",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "db:sync:neighborhoods": "tsx scripts/sync-neighborhoods.ts",
    "db:seed:reports": "tsx scripts/seed-reports.ts",
    "db:seed:admin": "tsx scripts/seed-admin.ts",
    "db:seed:adoption-demo": "tsx scripts/seed-adoption-demo.ts",
    "db:seed:board-posts": "tsx scripts/seed-board-posts.ts",
    "db:seed:comment-best-demo": "tsx scripts/seed-comment-best-demo.ts",
    "db:seed:users": "tsx scripts/seed-users.ts",
    "db:seed:search-cases": "tsx scripts/seed-search-cases.ts",
    "db:seed:passwords": "tsx scripts/seed-passwords.ts",
    "db:backfill:guest-authors": "tsx scripts/backfill-guest-authors.ts",
    "db:verify:guest-authors": "tsx scripts/verify-guest-author-backfill.ts",
    "db:check:guest-legacy-cleanup": "tsx scripts/check-guest-legacy-cleanup-readiness.ts",
    "db:rehearse:guest-legacy-cleanup": "tsx scripts/rehearse-guest-legacy-cleanup.ts",
    "db:cleanup:auth-audits": "tsx scripts/cleanup-auth-audits.ts",
    "db:cleanup:notifications": "tsx scripts/cleanup-notifications.ts",
    "db:repair:post-integrity": "tsx scripts/repair-post-integrity.ts",
    "db:cleanup:upload-assets": "tsx scripts/cleanup-upload-assets.ts",
    "db:backfill:upload-media-proxy": "tsx scripts/backfill-upload-media-proxy.ts",
    "db:cleanup:search-terms": "tsx scripts/cleanup-search-terms.ts",
    "db:cleanup:legacy-search-setting": "tsx scripts/cleanup-legacy-site-setting.ts",
    "docs:refresh": "node ../scripts/refresh-docs-index.mjs",
    "docs:refresh:check": "node ../scripts/refresh-docs-index.mjs --check",
    "agent:prompt": "tsx scripts/generate-agent-prompt.ts",
    "growth:day1:handoff": "tsx scripts/generate-day1-growth-handoff.ts",
    "ops:oauth:manual-report": "tsx scripts/generate-oauth-manual-check-report.ts",
    "ops:oauth:preflight": "tsx scripts/generate-oauth-manual-check-report.ts --strict-base-url 1 --out /tmp/oauth-manual-check.md",
    "ops:oauth:verify-manual": "tsx scripts/verify-oauth-manual-check.ts",
    "ops:oauth:update-manual": "tsx scripts/update-oauth-manual-check.ts",
    "ops:check:auth-email-readiness": "tsx scripts/check-auth-email-readiness.ts",
    "ops:check:health": "tsx scripts/check-health-endpoint.ts",
    "ops:check:security-env": "tsx scripts/check-security-env.ts",
    "ops:check:security-env:strict": "NODE_ENV=production SECURITY_ENV_STRICT=1 tsx scripts/check-security-env.ts",
    "ops:check:sentry": "tsx scripts/check-sentry-ingestion.ts",
    "ops:prewarm": "tsx scripts/prewarm-deployment.ts",
    "ops:perf:snapshot": "tsx scripts/collect-latency-snapshot.ts",
    "search:check:cases": "tsx scripts/check-search-cases.ts",
    "test:flow:notification-comment": "tsx scripts/e2e-notification-comment-flow.ts",
    "test:flow:new-user-policy": "tsx scripts/e2e-new-user-safety-policy-flow.ts",
    "perf:feed:scroll": "playwright test e2e/feed-scroll-performance.spec.ts --project=chromium",
    "test:e2e:upload": "PLAYWRIGHT_BASE_URL=http://localhost:3000 playwright test e2e/image-upload-flow.spec.ts --project=chromium",
    "test:e2e:feed-loading": "PLAYWRIGHT_BASE_URL=http://localhost:3000 playwright test e2e/feed-loading-skeleton.spec.ts --project=chromium",
    "test:e2e:kakao-entry": "PLAYWRIGHT_BASE_URL=http://localhost:3000 playwright test e2e/kakao-login-entry.spec.ts --project=chromium",
    "test:e2e:naver-entry": "PLAYWRIGHT_BASE_URL=http://localhost:3000 playwright test e2e/naver-login-entry.spec.ts --project=chromium",
    "test:e2e:social-onboarding": "ENABLE_SOCIAL_DEV_LOGIN=1 PLAYWRIGHT_BASE_URL=http://localhost:3000 playwright test e2e/social-onboarding-flow.spec.ts --project=chromium",
    "test:e2e:social-real-oauth": "E2E_REAL_SOCIAL_OAUTH=1 PLAYWRIGHT_BASE_URL=http://localhost:3000 playwright test e2e/social-real-oauth-redirect.spec.ts --project=chromium",
    "test:e2e:notification-filters": "PLAYWRIGHT_BASE_URL=http://localhost:3000 playwright test e2e/notification-filter-controls.spec.ts --project=chromium",
    "test:e2e:admin-policies": "E2E_RECIPIENT_EMAIL=admin.platform@townpet.dev PLAYWRIGHT_BASE_URL=http://localhost:3000 playwright test e2e/admin-new-user-policy.spec.ts --project=chromium"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.7.4",
    "@prisma/client": "^5.22.0",
    "@vercel/blob": "^2.3.1",
    "next": "16.1.5",
    "next-auth": "5.0.0-beta.30",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "resend": "^4.1.0",
    "sharp": "^0.34.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.0.18",
    "dotenv": "^17.3.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.5",
    "prisma": "^5.22.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vite-tsconfig-paths": "^4.3.2",
    "vitest": "^4.0.18"
  },
  "packageManager": "pnpm@9.12.3+sha512.cce0f9de9c5a7c95bef944169cc5dfe8741abfb145078c0d508b868056848a87c81e626246cb60967cbd7fd29a6c062ef73ff840d96b3c86c40ac92cf4a813ee"
}
